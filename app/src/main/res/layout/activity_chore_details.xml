<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/choreDetailsLayout"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- ==================== -->
    <!-- HERO / STATUS HEADER -->
    <!-- ==================== -->
    <LinearLayout
        android:id="@+id/choreDetails_heroLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginVertical="48dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Chore Hero Name -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/choreDetails_choreHeroNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chore Name"
            android:textAlignment="center"
            android:textAppearance="?attr/textAppearanceHeadlineLarge"
            android:layout_marginBottom="6dp" />

        <!-- Chore Hero Progress ring -->
        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/choreDetails_choreHeroProgressIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:indicatorSize="120dp"
            app:trackThickness="12dp"
            app:trackColor="?attr/colorSurfaceDim"
            app:indicatorColor="?attr/colorPrimary"/>

        <!-- Chore Hero Timer -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/choreDetails_choreHeroTimerTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00:00:00"
            android:textAlignment="center"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- DIVIDER -->
    <View
        android:id="@+id/choreDetails_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginHorizontal="24dp"
        android:background="@color/material_dynamic_secondary50"
        app:layout_constraintTop_toBottomOf="@id/choreDetails_heroLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= -->
    <!-- SCROLLING FORM -->
    <!-- ================= -->
    <ScrollView
        android:id="@+id/choreDetails_formLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/choreDetails_divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:clipToPadding="false">

        <!-- Form -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="24dp"
            android:paddingHorizontal="48dp">

            <!-- Active toggle -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/choreDetails_choreIsActiveLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/chore_active_label"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/choreDetails_choreIsActiveSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:checked="true"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Chore name -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/choreDetails_choreNameLayout"
                style="?attr/textInputOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/chore_name_label"
                app:helperText="@string/chore_name_support">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/choreDetails_choreNameEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:enabled="false" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Due date -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/choreDetails_choreEndAtLayout"
                style="?attr/textInputOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/chore_due_date_hint"
                app:helperText="@string/chore_due_date_support"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/calendar"
                app:endIconContentDescription="@string/open_date_picker">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/choreDetails_choreEndAtEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:cursorVisible="false"
                    android:inputType="none"
                    android:longClickable="false" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Repeat toggle -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/choreDetails_choreIsRepeatLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/chore_repeat_label"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/choreDetails_choreIsRepeatSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:enabled="false"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Repeat frequency -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/choreDetails_choreRepeatDaysLayout"
                style="?attr/textInputOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="@string/chore_repeat_frequency_label"
                app:helperText="@string/chore_repeat_frequency_support"
                app:startIconDrawable="@drawable/remove"
                app:startIconContentDescription="@string/decrement"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/add"
                app:endIconContentDescription="@string/increment">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/choreDetails_choreRepeatDaysEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:cursorVisible="false"
                    android:inputType="none"
                    android:longClickable="false"
                    android:gravity="center"
                    android:text="0"
                    android:enabled="false"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Alert toggle -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/choreDetails_choreIsAlertLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/chore_alert_label"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/choreDetails_choreIsAlertSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:enabled="false"/>
            </androidx.constraintlayout.widget.ConstraintLayout>


        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM ACTION BAR -->
    <LinearLayout
        android:id="@+id/choreDetails_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Delete (left) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/choreDetails_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/delete"
            app:useCompatPadding="false"
            android:outlineProvider="none"
            app:backgroundTint="?attr/colorPrimaryContainer" />

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Save (right) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/choreDetails_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/save"
            app:useCompatPadding="false"
            android:outlineProvider="none"
            app:backgroundTint="?attr/colorPrimaryContainer"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
