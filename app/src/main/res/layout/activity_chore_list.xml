<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MATERIAL 3 SEARCH BAR -->
    <com.google.android.material.search.SearchBar
        android:id="@+id/choreList_search"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Search chores"
        android:layout_margin="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- RecyclerView content -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/choreDetails_recyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="88dp"
        app:layout_constraintTop_toBottomOf="@+id/choreList_search"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- BOTTOM ACTION BAR -->
    <LinearLayout
        android:id="@+id/choreDetails_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Report (left) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/choreList_report"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/report"
            app:useCompatPadding="false"
            android:outlineProvider="none"
            android:enabled="true"/>

        <!-- Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- New (right) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/choreList_add"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/add"
            app:useCompatPadding="false"
            android:outlineProvider="none"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
